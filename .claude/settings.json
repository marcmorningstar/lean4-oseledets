{
  "permissions": {
    "allow": [
      "Bash(lake env lean *)",
      "Bash(lake build)",
      "Bash(lake build *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(firecrawl search *)",
      "Bash(firecrawl scrape *)",
      "Bash(firecrawl map *)"
    ],
    "deny": [
      "Bash(git reset:*)",
      "Bash(git push:*)",
      "Bash(git clean:*)",
      "Bash(git stash:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-subagent-git.sh"
          }
        ]
      }
    ]
  }
}
