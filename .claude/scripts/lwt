#!/usr/bin/env bash
# lwt — Lean WorkTree launcher for this repo.
#
# Delegates to the `lwt` tool shipped with the leancheck Claude plugin (the single, maintained
# implementation; see github.com/marcmorningstar/leancheck). It provisions one collision-free,
# build-warm git worktree per agent so many agents can grind proofs in parallel without racing
# each other's `.lake/build`. Mirrors `git worktree`:
#
#   .claude/scripts/lwt add <branch> [base]      # create + provision + warm; prints the path (last line)
#   .claude/scripts/lwt remove <branch|path> [--delete-branch]
#   .claude/scripts/lwt list
#   .claude/scripts/lwt prune
#
# Repo-specific defaults (overridable): worktrees live under /home/vscode (overlay/ext4) because the
# checkout itself is on a slow 9p mount; the shared .lake comes from this checkout.
set -euo pipefail
export LWT_BASE_DIR="${LWT_BASE_DIR:-/home/vscode}"
export LWT_MAIN="${LWT_MAIN:-/workspaces/lean4-oseledets}"

for c in \
  "$HOME/.claude/plugins/marketplaces/lean-tools/leancheck/scripts/lwt.py" \
  "$HOME"/.claude/plugins/cache/lean-tools/leancheck/*/scripts/lwt.py; do
  if [ -f "$c" ]; then exec python3 "$c" "$@"; fi
done

echo "lwt: leancheck plugin not found. Install it:" >&2
echo "  claude plugin marketplace add marcmorningstar/leancheck" >&2
echo "  claude plugin install leancheck@lean-tools" >&2
exit 1
