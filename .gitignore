# Firecrawl CLI local cache / scrape output
.firecrawl/

# Lean 4 build artifacts
/.lake/
/build/
*.olean
*.ilean
*.trace

# Blueprint build artifacts (leanblueprint pdf/web output + extracted decl list)
/blueprint/web/
/blueprint/print/
/blueprint/lean_decls
/home_page/_site/
/home_page/.jekyll-cache/

# LaTeX byproducts that land in blueprint/src/ when running xelatex/latexmk there directly
# (the canonical leanblueprint output goes to blueprint/{print,web}/, ignored above).
/blueprint/src/*.aux
/blueprint/src/*.paux
/blueprint/src/*.fls
/blueprint/src/*.fdb_latexmk
/blueprint/src/*.log
/blueprint/src/*.out
/blueprint/src/*.pdf
/blueprint/src/*.xdv
/blueprint/src/*.synctex.gz
/blueprint/src/*.bbl
/blueprint/src/*.blg

# Claude Code session state — agent worktrees are temporary working copies
# created during parallel agent execution, not source.
.claude/worktrees/
.claude/sessions/
.claude/cache/
.claude/local/

# Python bytecode (leancheck engine + hooks)
__pycache__/
*.pyc

# OS-specific
.DS_Store
Thumbs.db

# Editor
*~
*.swp
.vscode/

# Scratch
prompt.md
build.log
/scratch_*.lean
